<%# Override: lib/template_base/app/views/layouts/application.html.erb %>
<%# Adds the fork's ledger navigation, PWA manifest link, and conditional header so unauth pages stay full-bleed. %>
<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || TemplateBase.config.application_name %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="manifest" href="<%= pwa_manifest_path(format: :json) %>">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-neutral-primary-soft text-body antialiased">
    <% if user_signed_in? %>
      <header class="border-b border-default bg-neutral-primary/90 backdrop-blur-sm">
        <div class="mx-auto flex w-full max-w-7xl flex-col gap-4 px-6 py-4 sm:px-8 lg:flex-row lg:items-start lg:justify-between">
          <div>
            <%= link_to TemplateBase.config.application_name, root_path, class: "text-lg font-semibold tracking-tight text-heading" %>
            <p class="text-sm text-body-subtle"><%= TemplateBase.config.domain %></p>
          </div>

          <% navigation_links = [
            [ "Dashboard", dashboard_path ],
            [ "Reports", reports_path ],
            [ t("layouts.application.insights"), insight_explorers_path ],
            [ "Data", data_management_path ],
            [ "Imports", new_import_batch_path ],
            [ "Accounts", accounts_path ],
            [ "Categories", transaction_categories_path ],
            [ "Tags", transaction_tag_groups_path ],
            [ "Transactions", transactions_path ],
            [ "Receipts", new_receipt_recognition_path ],
            [ "Exchange Rates", exchange_rate_catalog_path ],
            [ t("layouts.application.profile"), user_profile_path ],
            [ "Preferences", user_preference_path ],
            [ "API Tokens", api_tokens_path ],
            [ "External Auth", external_authentications_path ],
            [ "2FA", two_factor_authentication_path ],
            [ "App Lock", application_lock_path ],
            [ "Clear Data", new_ledger_clearance_path ]
          ] %>

          <details class="w-full lg:hidden">
            <summary class="cursor-pointer list-none text-body bg-neutral-secondary-medium box-border border border-default-medium hover:bg-neutral-tertiary-medium hover:text-heading focus:ring-4 focus:ring-neutral-tertiary shadow-xs font-medium leading-5 rounded-base text-sm px-4 py-2.5 focus:outline-none">Menu</summary>
            <nav class="mt-3 grid gap-1 rounded-base border border-default bg-neutral-primary-soft p-3 shadow-xs text-sm font-medium">
              <% navigation_links.each do |label, path| %>
                <%= link_to label, path, class: "rounded-base px-3 py-2 text-body hover:bg-neutral-secondary-medium hover:text-heading" %>
              <% end %>
              <div class="mt-2 border-t border-default pt-3">
                <p class="mb-2 px-3 text-sm text-body-subtle"><%= current_user.name.presence || current_user.email %></p>
                <%= button_to "Sign out", destroy_user_session_path, method: :delete, form: { class: "w-full" }, class: "w-full text-start text-body bg-neutral-secondary-medium box-border border border-default-medium hover:bg-neutral-tertiary-medium hover:text-heading focus:ring-4 focus:ring-neutral-tertiary shadow-xs font-medium leading-5 rounded-base text-sm px-4 py-2.5 focus:outline-none" %>
              </div>
            </nav>
          </details>

          <nav class="hidden max-w-5xl flex-wrap items-center justify-end gap-x-3 gap-y-2 text-sm font-medium lg:flex">
            <% navigation_links.each do |label, path| %>
              <%= link_to label, path, class: "text-sm font-medium text-body hover:text-heading" %>
            <% end %>
            <span class="text-body-subtle"><%= current_user.name.presence || current_user.email %></span>
            <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "text-body bg-neutral-secondary-medium box-border border border-default-medium hover:bg-neutral-tertiary-medium hover:text-heading focus:ring-4 focus:ring-neutral-tertiary shadow-xs font-medium leading-5 rounded-base text-sm px-4 py-2.5 focus:outline-none" %>
          </nav>
        </div>
      </header>
    <% end %>

    <%= render(FlashComponent.new(
      flash: flash,
      hide_alert: instance_variable_defined?(:@hide_flash_alert) && @hide_flash_alert
    )) %>

    <% full_bleed_auth_page = devise_controller? && !user_signed_in? %>
    <% full_bleed_unlock_page = controller_path == "application_lock_sessions" %>
    <main class="<%= full_bleed_auth_page || full_bleed_unlock_page ? "min-h-screen" : "mx-auto flex w-full max-w-7xl flex-col px-6 pb-16 pt-10 sm:px-8" %>">
      <%= yield %>
    </main>

    <%= turbo_frame_tag "modal_content" %>
  </body>
</html>
