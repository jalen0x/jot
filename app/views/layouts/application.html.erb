<%# Override: lib/template_base/app/views/layouts/application.html.erb %>
<%# Adds the fork's ledger navigation, PWA manifest link, and conditional app shell. %>
<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || TemplateBase.config.application_name %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="manifest" href="<%= pwa_manifest_path(format: :json) %>">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <% show_app_shell = user_signed_in? && controller_path != "application_lock_sessions" %>
  <body class="min-h-screen bg-neutral-secondary-soft text-body antialiased">
    <% if show_app_shell %>
      <%= render "layouts/app_shell_sidebar" %>

      <div class="min-h-screen lg:ps-72">
        <header class="sticky top-0 z-30 border-b border-default bg-neutral-primary/90 backdrop-blur-sm">
          <div class="flex h-16 items-center justify-between gap-4 px-4 sm:px-6 lg:px-8">
            <div class="flex min-w-0 items-center gap-3">
              <button type="button" data-drawer-target="app-sidebar" data-drawer-toggle="app-sidebar" aria-controls="app-sidebar" class="inline-flex h-10 w-10 items-center justify-center rounded-base border border-default-medium bg-neutral-primary text-heading shadow-xs hover:bg-neutral-tertiary-soft focus:outline-none focus:ring-4 focus:ring-neutral-tertiary lg:hidden">
                <span class="sr-only"><%= t("layouts.application.open_menu") %></span>
                <svg class="h-5 w-5" aria-hidden="true" viewBox="0 0 24 24" fill="none">
                  <path d="M5 7h14M5 12h14M5 17h10" stroke="currentColor" stroke-linecap="round" stroke-width="2" />
                </svg>
              </button>

              <div class="min-w-0">
                <p class="truncate text-sm font-medium text-body-subtle"><%= TemplateBase.config.domain %></p>
                <p class="truncate text-base font-semibold text-heading"><%= content_for(:title) || TemplateBase.config.application_name %></p>
              </div>
            </div>

            <div class="flex shrink-0 items-center gap-3">
              <%= render(ButtonComponent.new(href: new_transaction_path, class: "hidden sm:inline-flex", data: { turbo_frame: "modal_content" })) { t("layouts.application.new_transaction") } %>

              <button id="app-user-menu-button" data-dropdown-toggle="app-user-menu" data-dropdown-placement="bottom-end" type="button" class="flex h-10 w-10 items-center justify-center rounded-full border border-default bg-brand-softer text-sm font-semibold text-fg-brand shadow-xs focus:outline-none focus:ring-4 focus:ring-brand-medium" aria-expanded="false">
                <span class="sr-only"><%= t("layouts.application.open_user_menu") %></span>
                <%= (current_user.name.presence || current_user.email).first.upcase %>
              </button>
              <div id="app-user-menu" class="z-50 hidden w-64 divide-y divide-default rounded-base border border-default bg-neutral-primary-soft shadow-lg">
                <div class="px-4 py-3">
                  <p class="truncate text-sm font-semibold text-heading"><%= current_user.name.presence || current_user.email %></p>
                  <p class="mt-1 truncate text-xs text-body-subtle"><%= current_user.email %></p>
                </div>
                <ul class="py-2 text-sm text-body" aria-labelledby="app-user-menu-button">
                  <li><%= link_to t("layouts.application.profile"), user_profile_path, class: "block px-4 py-2 hover:bg-neutral-tertiary-soft hover:text-heading" %></li>
                  <li><%= link_to t("layouts.application.preferences"), user_preference_path, class: "block px-4 py-2 hover:bg-neutral-tertiary-soft hover:text-heading" %></li>
                  <li><%= link_to t("layouts.application.app_lock"), application_lock_path, class: "block px-4 py-2 hover:bg-neutral-tertiary-soft hover:text-heading" %></li>
                </ul>
                <div class="py-2">
                  <%= button_to t("layouts.application.sign_out"), destroy_user_session_path, method: :delete, form: { class: "w-full" }, class: "block w-full px-4 py-2 text-start text-sm text-body hover:bg-neutral-tertiary-soft hover:text-heading" %>
                </div>
              </div>
            </div>
          </div>
        </header>

        <%= render(FlashComponent.new(
          flash: flash,
          hide_alert: instance_variable_defined?(:@hide_flash_alert) && @hide_flash_alert
        )) %>

        <main class="mx-auto flex w-full max-w-[1500px] flex-col px-4 pb-12 pt-6 sm:px-6 lg:px-8">
          <%= yield %>
        </main>
      </div>
    <% else %>
      <%= render(FlashComponent.new(
        flash: flash,
        hide_alert: instance_variable_defined?(:@hide_flash_alert) && @hide_flash_alert
      )) %>

      <% full_bleed_auth_page = devise_controller? && !user_signed_in? %>
      <% full_bleed_unlock_page = controller_path == "application_lock_sessions" %>
      <main class="<%= full_bleed_auth_page || full_bleed_unlock_page ? "min-h-screen" : "mx-auto flex w-full max-w-7xl flex-col px-6 pb-16 pt-10 sm:px-8" %>">
        <%= yield %>
      </main>
    <% end %>

    <%= turbo_frame_tag "modal_content" %>
  </body>
</html>
