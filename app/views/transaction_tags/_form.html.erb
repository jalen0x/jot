<%# locals: (transaction_tag:, transaction_tag_groups:, submit_label: nil, submitting_label: nil) %>
<% field_classes = "bg-neutral-secondary-medium border border-default-medium text-heading text-sm rounded-base focus:ring-brand focus:border-brand block w-full px-3 py-2.5 shadow-xs placeholder:text-body" %>
<% submit_label ||= t(".create") %>
<% submitting_label ||= t(".saving") %>

<%= form_with model: transaction_tag, class: "rounded-base border border-default bg-neutral-primary-soft p-5 shadow-xs" do |form| %>
  <% if transaction_tag.errors.any? %>
    <div class="mb-5 rounded-base border border-danger bg-danger-soft p-4 text-sm text-fg-danger-strong">
      <p class="font-medium"><%= t(".save_failed") %></p>
      <ul class="mt-2 list-disc ps-5">
        <% transaction_tag.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= render FormField::InputComponent.new(form: form, field: :name, label: t(".name"), autofocus: true, required: true) %>

  <div class="mb-4">
    <%= form.label :transaction_tag_group_id, t(".group"), class: "mb-2 block text-sm font-medium text-heading" %>
    <%= form.collection_select :transaction_tag_group_id, transaction_tag_groups, :id, :name, { include_blank: t(".ungrouped") }, class: field_classes %>
  </div>

  <%= render FormField::CheckboxComponent.new(form: form, field: :hidden, label: t(".hidden")) %>

  <div class="flex items-center justify-end gap-3">
    <%= render(ButtonComponent.new(variant: :secondary, href: transaction_tag_groups_path)) { t(".cancel") } %>
    <%= render(ButtonComponent.new(type: :submit, data: { turbo_submits_with: submitting_label })) { submit_label } %>
  </div>
<% end %>
