<%# locals: (transaction_category:, submit_label: nil, submitting_label: nil) %>
<% field_classes = "bg-neutral-secondary-medium border border-default-medium text-heading text-sm rounded-base focus:ring-brand focus:border-brand block w-full px-3 py-2.5 shadow-xs placeholder:text-body" %>
<% submit_label ||= t(".create") %>
<% submitting_label ||= t(".saving") %>

<%= form_with model: transaction_category, class: "rounded-base border border-default bg-neutral-primary-soft p-5 shadow-xs" do |form| %>
  <% if transaction_category.errors.any? %>
    <div class="mb-5 rounded-base border border-danger bg-danger-soft p-4 text-sm text-fg-danger-strong">
      <p class="font-medium"><%= t(".save_failed") %></p>
      <ul class="mt-2 list-disc ps-5">
        <% transaction_category.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= render FormField::InputComponent.new(form: form, field: :name, label: t(".name"), autofocus: true, required: true) %>

  <div class="mb-4 grid gap-4 sm:grid-cols-3">
    <div>
      <%= form.label :category_type, t(".type"), class: "mb-2 block text-sm font-medium text-heading" %>
      <%= form.select :category_type, TransactionCategory.category_types.keys.map { |key| [ key.humanize, key ] }, {}, class: field_classes %>
    </div>
    <div>
      <%= form.label :icon_key, t(".icon"), class: "mb-2 block text-sm font-medium text-heading" %>
      <%= form.number_field :icon_key, min: 1, required: true, class: field_classes %>
    </div>
    <%= render FormField::InputComponent.new(form: form, field: :color_hex, label: t(".color"), placeholder: t(".color_placeholder"), required: true) %>
  </div>

  <% parent_category_options = [ [ t(".no_parent"), "" ] ] + Array(@parent_category_options).map { |parent_category| [ parent_category.name, parent_category.to_param ] } %>
  <div class="mb-4">
    <%= form.label :parent_category_id, t(".parent_category"), class: "mb-2 block text-sm font-medium text-heading" %>
    <%= form.select :parent_category_id, options_for_select(parent_category_options, transaction_category.parent_category&.to_param), {}, class: field_classes %>
  </div>

  <%= render FormField::CheckboxComponent.new(form: form, field: :hidden, label: t(".hidden")) %>

  <%= render FormField::InputComponent.new(form: form, field: :comment, label: t(".comment"), type: :textarea) %>

  <div class="flex items-center justify-end gap-3">
    <%= render(ButtonComponent.new(variant: :secondary, href: transaction_categories_path)) { t(".cancel") } %>
    <%= render(ButtonComponent.new(type: :submit, data: { turbo_submits_with: submitting_label })) { submit_label } %>
  </div>
<% end %>
