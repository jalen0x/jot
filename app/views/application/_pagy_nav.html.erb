<%# locals: (pagy:) -%>
<% return if pagy.pages <= 1 %>
<%
  link_classes = "flex h-9 items-center justify-center border border-default-medium bg-neutral-primary px-3 text-body hover:bg-neutral-tertiary-medium hover:text-heading"
  disabled_classes = "flex h-9 items-center justify-center border border-default-medium bg-neutral-primary px-3 text-body-subtle"
  current_classes = "flex h-9 items-center justify-center border border-default-medium bg-brand-softer px-3 font-medium text-fg-brand"
  a_lambda = pagy.send(:a_lambda)
%>
<nav aria-label="<%= t("pagination.label") %>" class="mt-6 flex flex-col items-center justify-between gap-3 sm:flex-row">
  <p class="text-sm text-body-subtle"><%= t("pagination.info", from: pagy.from, to: pagy.to, count: pagy.count) %></p>

  <div class="inline-flex -space-x-px text-sm">
    <% if pagy.previous %>
      <%== a_lambda.(pagy.previous, t("pagination.previous"), classes: "#{link_classes} rounded-s-base", aria_label: t("pagination.previous")) %>
    <% else %>
      <a role="link" aria-disabled="true" class="<%= disabled_classes %> rounded-s-base cursor-not-allowed"><%= t("pagination.previous") %></a>
    <% end %>

    <% pagy.send(:series).each do |item| %>
      <% case item %>
      <% when Integer %>
        <%== a_lambda.(item, classes: link_classes, aria_label: t("pagination.go_to_page", page: item)) %>
      <% when String %>
        <a role="link" aria-disabled="true" aria-current="page" class="<%= current_classes %>"><%= item %></a>
      <% when :gap %>
        <a role="separator" aria-disabled="true" class="<%= disabled_classes %>">&hellip;</a>
      <% end %>
    <% end %>

    <% if pagy.next %>
      <%== a_lambda.(pagy.next, t("pagination.next"), classes: "#{link_classes} rounded-e-base", aria_label: t("pagination.next")) %>
    <% else %>
      <a role="link" aria-disabled="true" class="<%= disabled_classes %> rounded-e-base cursor-not-allowed"><%= t("pagination.next") %></a>
    <% end %>
  </div>
</nav>
