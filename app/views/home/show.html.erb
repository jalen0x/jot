<% content_for :title, t(".title") %>

<section class="grid min-h-[calc(100vh-8rem)] overflow-hidden rounded-base border border-default bg-neutral-primary-soft shadow-xs lg:grid-cols-[minmax(0,1fr)_minmax(24rem,32rem)]">
  <div class="relative flex flex-col justify-between overflow-hidden border-b border-default p-8 lg:border-b-0 lg:border-e lg:p-10">
    <div>
      <%= link_to root_path, class: "inline-flex items-center gap-3 text-heading" do %>
        <span class="flex h-11 w-11 items-center justify-center rounded-base bg-brand text-base font-bold text-white shadow-xs">
          <%= TemplateBase.config.application_name.first %>
        </span>
        <span>
          <span class="block text-xl font-semibold tracking-tight"><%= TemplateBase.config.application_name %></span>
          <span class="block text-sm text-body-subtle"><%= t(".ledger_console") %></span>
        </span>
      <% end %>
    </div>

    <div class="relative z-10 my-10 max-w-2xl lg:my-16">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-fg-brand"><%= t(".eyebrow") %></p>
      <h1 class="mt-4 text-4xl font-semibold leading-tight tracking-tight text-heading sm:text-5xl"><%= t(".heading") %></h1>
      <p class="mt-4 max-w-xl text-base leading-7 text-body"><%= t(".description") %></p>
      <%= image_tag "girl-and-computer.svg", class: "mt-10 max-h-[22rem] w-full object-contain", alt: "" %>
    </div>

    <div class="absolute -bottom-24 -left-24 h-72 w-72 rounded-full bg-brand-softer"></div>
    <div class="absolute right-10 top-20 h-28 w-28 rounded-base border border-default bg-neutral-secondary-soft"></div>
  </div>

  <aside class="flex flex-col justify-center bg-neutral-primary p-8 lg:p-10">
    <div class="max-w-md">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-body-subtle"><%= t(".workspace") %></p>
      <h2 class="mt-3 text-2xl font-semibold text-heading"><%= t(".panel_heading") %></h2>
      <p class="mt-3 text-sm leading-6 text-body"><%= t(".panel_description") %></p>

      <div class="mt-6 flex flex-wrap gap-3">
        <% if user_signed_in? %>
          <%= render(ButtonComponent.new(href: edit_user_registration_path)) { t(".open_account_settings") } %>
          <%= render(ButtonComponent.new(variant: :secondary, href: "/lookbook")) { t(".browse_lookbook") } if Rails.env.development? %>
        <% else %>
          <%= render(ButtonComponent.new(href: new_user_registration_path, data: { turbo_frame: "modal_content" })) { t(".create_account") } %>
          <%= render(ButtonComponent.new(variant: :secondary, href: new_user_session_path, data: { turbo_frame: "modal_content" })) { t(".sign_in") } %>
          <%= link_to t(".continue_with_github"), user_github_omniauth_authorize_path, class: "text-heading bg-neutral-primary border border-default-medium hover:bg-neutral-secondary-soft focus:ring-4 focus:ring-neutral-tertiary shadow-xs font-medium leading-5 rounded-base text-sm px-4 py-2.5 focus:outline-none" %>
        <% end %>
      </div>

      <div class="mt-8 grid gap-3 text-sm text-body">
        <div class="rounded-base border border-default bg-neutral-secondary-soft px-4 py-4"><%= t(".feature_accounts") %></div>
        <div class="rounded-base border border-default bg-neutral-secondary-soft px-4 py-4"><%= t(".feature_reports") %></div>
        <div class="rounded-base border border-default bg-neutral-secondary-soft px-4 py-4"><%= t(".feature_security") %></div>
      </div>

      <p class="mt-8 text-sm leading-6 text-body-subtle">
        <%= t(".support_contact") %>
        <a href="mailto:<%= TemplateBase.config.support_email %>" class="font-medium text-fg-brand hover:underline"><%= TemplateBase.config.support_email %></a>
      </p>
    </div>
  </aside>
</section>
