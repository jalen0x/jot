<% content_for :title, "Import status" %>

<section class="mx-auto w-full max-w-3xl">
  <div class="mb-6">
    <p class="text-sm font-medium uppercase tracking-wide text-body-subtle">Ledger</p>
    <h1 class="mt-1 text-3xl font-semibold tracking-tight text-heading">Import status</h1>
    <p class="mt-2 text-sm text-body"><%= @import_batch.source_filename.presence || "Pasted import data" %></p>
  </div>

  <div class="bg-neutral-primary-soft border border-default rounded-base p-6 shadow-xs">
    <dl class="grid gap-4 sm:grid-cols-3">
      <div>
        <dt class="text-sm font-medium text-body-subtle">Status</dt>
        <dd class="mt-1 text-lg font-semibold text-heading"><%= @import_batch.status.humanize %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-body-subtle">Imported rows</dt>
        <dd class="mt-1 text-lg font-semibold text-heading"><%= @import_batch.imported_count %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-body-subtle">Created</dt>
        <dd class="mt-1 text-lg font-semibold text-heading"><%= l(@import_batch.created_at, format: :short) %></dd>
      </div>
    </dl>

    <% if @import_batch.error_message.present? %>
      <div class="mt-5 rounded-base border border-danger bg-neutral-primary p-4 text-sm text-danger"><%= @import_batch.error_message %></div>
    <% end %>

    <div class="mt-6 flex justify-end gap-3">
      <%= render(ButtonComponent.new(variant: :secondary, href: new_import_batch_path)) { "Import another" } %>
      <%= render(ButtonComponent.new(href: transactions_path)) { "View transactions" } %>
    </div>
  </div>
</section>
