<% content_for :title, t(".title") %>
<% field_classes = "bg-neutral-secondary-medium border border-default-medium text-heading text-sm rounded-base focus:ring-brand focus:border-brand block w-full px-3 py-2.5 shadow-xs placeholder:text-body" %>

<section class="max-w-2xl space-y-8">
  <div class="space-y-3">
    <p class="text-sm font-medium uppercase tracking-wide text-fg-brand"><%= t(".eyebrow") %></p>
    <h1 class="text-3xl font-semibold tracking-tight text-heading"><%= t(".heading") %></h1>
    <p class="text-body"><%= t(".description") %></p>
  </div>

  <%= form_with model: @user_preference, url: user_preference_path, class: "bg-neutral-primary-soft border border-default rounded-base p-6 shadow-xs space-y-5" do |form| %>
    <% if @user_preference.errors.any? %>
      <div class="rounded-base border border-danger bg-neutral-primary p-4 text-sm text-danger">
        <p class="font-medium"><%= t(".save_failed") %></p>
        <ul class="mt-2 list-disc ps-5">
          <% @user_preference.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :default_currency_code, t(".default_currency_code"), class: "mb-2 block text-sm font-medium text-heading" %>
      <%= form.text_field :default_currency_code, required: true, maxlength: 3, class: field_classes %>
      <p class="mt-2 text-sm text-body-subtle"><%= t(".default_currency_help") %></p>
    </div>

    <div>
      <%= form.label :default_account_id, t(".default_account"), class: "mb-2 block text-sm font-medium text-heading" %>
      <%= form.collection_select :default_account_id, @default_account_options, :id, :name, { include_blank: t(".default_account_none") }, class: field_classes %>
      <p class="mt-2 text-sm text-body-subtle"><%= t(".default_account_help") %></p>
    </div>

    <div>
      <%= form.label :locale, t(".locale"), class: "mb-2 block text-sm font-medium text-heading" %>
      <%= form.select :locale, UserPreference::SUPPORTED_LOCALES.map { |locale| [ t(".locales.#{locale}"), locale ] }, {}, class: field_classes %>
      <p class="mt-2 text-sm text-body-subtle"><%= t(".locale_help") %></p>
    </div>

    <div>
      <%= form.label :date_format, t(".date_format"), class: "mb-2 block text-sm font-medium text-heading" %>
      <%= form.select :date_format, UserPreference::SUPPORTED_DATE_FORMATS.map { |date_format| [ t(".date_formats.#{date_format}"), date_format ] }, {}, class: field_classes %>
      <p class="mt-2 text-sm text-body-subtle"><%= t(".date_format_help") %></p>
    </div>

    <div>
      <%= form.label :number_format, t(".number_format"), class: "mb-2 block text-sm font-medium text-heading" %>
      <%= form.select :number_format, UserPreference::SUPPORTED_NUMBER_FORMATS.map { |number_format| [ t(".number_formats.#{number_format}"), number_format ] }, {}, class: field_classes %>
      <p class="mt-2 text-sm text-body-subtle"><%= t(".number_format_help") %></p>
    </div>

    <div class="flex justify-end gap-3">
      <%= render(ButtonComponent.new(variant: :secondary, href: dashboard_path)) { t(".cancel") } %>
      <%= render(ButtonComponent.new(type: :submit, data: { turbo_submits_with: t(".saving") })) { t(".save") } %>
    </div>
  <% end %>
</section>
