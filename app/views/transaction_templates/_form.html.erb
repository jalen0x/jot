<%# locals: (transaction_template:, accounts:, transaction_categories:, transaction_tags:, submit_label: nil, submitting_label: nil) %>
<% field_classes = "bg-neutral-secondary-medium border border-default-medium text-heading text-sm rounded-base focus:ring-brand focus:border-brand block w-full px-3 py-2.5 shadow-xs placeholder:text-body" %>
<% submit_label ||= t(".create") %>
<% submitting_label ||= t(".saving") %>

<%= form_with model: transaction_template, class: "rounded-base border border-default bg-neutral-primary-soft p-5 shadow-xs" do |form| %>
  <% if transaction_template.errors.any? %>
    <div class="mb-5 rounded-base border border-danger bg-danger-soft p-4 text-sm text-fg-danger-strong">
      <p class="font-medium"><%= t(".save_failed") %></p>
      <ul class="mt-2 list-disc ps-5">
        <% transaction_template.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-5 border-b border-default pb-4">
    <h2 class="text-lg font-semibold text-heading"><%= t(".details_heading") %></h2>
    <p class="mt-1 text-sm text-body"><%= t(".details_description") %></p>
  </div>

  <%= render FormField::InputComponent.new(form: form, field: :name, label: t(".name"), autofocus: true, required: true) %>

  <div class="mb-4 grid gap-4 sm:grid-cols-2">
    <div>
      <%= form.label :template_kind, t(".template_kind"), class: "mb-2 block text-sm font-medium text-heading" %>
      <%= form.select :template_kind, TransactionTemplate.template_kinds.keys.map { |key| [ key.humanize, key ] }, {}, class: field_classes %>
    </div>
    <div>
      <%= form.label :transaction_kind, t(".transaction_type"), class: "mb-2 block text-sm font-medium text-heading" %>
      <%= form.select :transaction_kind, TransactionTemplate.transaction_kinds.except("balance_adjustment").keys.map { |key| [ key.humanize, key ] }, {}, class: field_classes %>
    </div>
  </div>

  <div class="mb-4 grid gap-4 sm:grid-cols-2">
    <div>
      <%= form.label :account_id, t(".account"), class: "mb-2 block text-sm font-medium text-heading" %>
      <%= form.collection_select :account_id, accounts, :id, :name, { prompt: t(".choose_account") }, required: true, class: field_classes %>
    </div>
    <div>
      <%= form.label :destination_account_id, t(".destination_account"), class: "mb-2 block text-sm font-medium text-heading" %>
      <%= form.collection_select :destination_account_id, accounts, :id, :name, { include_blank: t(".not_a_transfer") }, class: field_classes %>
    </div>
  </div>

  <div class="mb-4 grid gap-4 sm:grid-cols-3">
    <div>
      <%= form.label :transaction_category_id, t(".category"), class: "mb-2 block text-sm font-medium text-heading" %>
      <%= form.collection_select :transaction_category_id, transaction_categories, :id, :name, { prompt: t(".choose_category") }, required: true, class: field_classes %>
    </div>
    <%= render FormField::InputComponent.new(form: form, field: :source_amount_cents, label: t(".source_cents"), type: :number, required: true) %>
    <%= render FormField::InputComponent.new(form: form, field: :destination_amount_cents, label: t(".destination_cents"), type: :number) %>
  </div>

  <div class="mb-4">
    <%= form.label :transaction_tag_ids, t(".tags"), class: "mb-2 block text-sm font-medium text-heading" %>
    <%= form.collection_select :transaction_tag_ids, transaction_tags, :id, :name, {}, multiple: true, class: field_classes %>
  </div>

  <div class="mb-4 flex items-center">
    <%= form.check_box :hide_amount, class: "w-4 h-4 border border-default-medium rounded-xs bg-neutral-secondary-medium focus:ring-2 focus:ring-brand-soft" %>
    <%= form.label :hide_amount, t(".hide_amount"), class: "select-none ms-2 text-sm font-medium text-heading" %>
  </div>

  <%= render FormField::CheckboxComponent.new(form: form, field: :hidden, label: t(".hidden")) %>

  <div class="mb-5 mt-6 border-b border-default pb-4">
    <h2 class="text-lg font-semibold text-heading"><%= t(".schedule_heading") %></h2>
    <p class="mt-1 text-sm text-body"><%= t(".schedule_description") %></p>
  </div>

  <div class="mb-4 grid gap-4 sm:grid-cols-3">
    <div>
      <%= form.label :schedule_frequency, t(".schedule_frequency"), class: "mb-2 block text-sm font-medium text-heading" %>
      <%= form.select :schedule_frequency, TransactionTemplate.schedule_frequencies.keys.map { |key| [ key.humanize, key ] }, {}, class: field_classes %>
    </div>
    <%= render FormField::InputComponent.new(form: form, field: :schedule_rule, label: t(".schedule_rule"), placeholder: t(".schedule_rule_placeholder")) %>
    <%= render FormField::InputComponent.new(form: form, field: :scheduled_at_minutes, label: t(".scheduled_minute"), type: :number) %>
  </div>

  <div class="mb-4 grid gap-4 sm:grid-cols-3">
    <%= render FormField::InputComponent.new(form: form, field: :schedule_start_on, label: t(".start_date"), type: :date) %>
    <%= render FormField::InputComponent.new(form: form, field: :schedule_end_on, label: t(".end_date"), type: :date) %>
    <%= render FormField::InputComponent.new(form: form, field: :timezone_utc_offset_minutes, label: t(".utc_offset_minutes"), type: :number) %>
  </div>

  <%= render FormField::InputComponent.new(form: form, field: :comment, label: t(".comment"), type: :textarea) %>

  <div class="flex items-center justify-end gap-3">
    <%= render(ButtonComponent.new(variant: :secondary, href: transaction_templates_path)) { t(".cancel") } %>
    <%= render(ButtonComponent.new(type: :submit, data: { turbo_submits_with: submitting_label })) { submit_label } %>
  </div>
<% end %>
