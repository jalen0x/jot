<% content_for :title, t(".title") %>

<section class="space-y-5">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-fg-brand"><%= t(".eyebrow") %></p>
      <h1 class="mt-1 text-2xl font-semibold tracking-tight text-heading sm:text-3xl"><%= t(".heading") %></h1>
      <p class="mt-2 max-w-2xl text-sm text-body"><%= t(".description") %></p>
    </div>

    <%= render(ButtonComponent.new(href: new_transaction_template_path)) { t(".new") } %>
  </div>

  <% if @transaction_templates.any? %>
    <div class="overflow-hidden rounded-base border border-default bg-neutral-primary-soft shadow-xs">
      <div class="overflow-x-auto">
        <table class="w-full text-start text-sm text-body">
          <thead class="border-b border-default bg-neutral-secondary-medium text-xs uppercase tracking-wide text-body-subtle">
            <tr>
              <th scope="col" class="px-5 py-3"><%= t(".template") %></th>
              <th scope="col" class="px-5 py-3"><%= t(".kind") %></th>
              <th scope="col" class="px-5 py-3"><%= t(".account") %></th>
              <th scope="col" class="px-5 py-3 text-end"><%= t(".amount") %></th>
              <th scope="col" class="px-5 py-3 text-end"><%= t(".actions") %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-default">
            <% @transaction_templates.each do |template| %>
              <tr id="<%= dom_id(template) %>" class="align-top hover:bg-neutral-secondary-soft">
                <td class="px-5 py-4">
                  <div class="max-w-md">
                    <div class="flex items-center gap-2">
                      <span class="rounded-base bg-brand-softer px-2 py-1 text-xs font-medium text-fg-brand"><%= template.template_kind.humanize %></span>
                      <h2 class="truncate font-semibold text-heading"><%= template.name %></h2>
                    </div>
                    <% if template.comment.present? %>
                      <p class="mt-2 text-sm text-body"><%= template.comment %></p>
                    <% end %>
                    <% if template.transaction_tags.any? %>
                      <div class="mt-3 flex flex-wrap gap-1.5">
                        <% template.transaction_tags.each do |tag| %>
                          <span class="rounded-base bg-neutral-secondary-medium px-2 py-0.5 text-xs font-medium text-heading"><%= tag.name %></span>
                        <% end %>
                      </div>
                    <% end %>
                    <% if template.scheduled? %>
                      <p class="mt-3 text-xs text-body-subtle">
                        <%= t(".schedule", frequency: template.schedule_frequency.humanize, minute: template.scheduled_at_minutes, offset: template.timezone_utc_offset_minutes) %>
                        <% if template.schedule_rule.present? %>
                          · <%= template.schedule_rule %>
                        <% end %>
                      </p>
                    <% end %>
                  </div>
                </td>
                <td class="px-5 py-4 text-body-subtle"><%= template.transaction_kind.humanize %></td>
                <td class="px-5 py-4">
                  <p class="font-medium text-heading"><%= template.account.name %></p>
                  <% if template.transaction_category.present? %>
                    <p class="mt-1 text-xs text-body-subtle"><%= template.transaction_category.name %></p>
                  <% end %>
                </td>
                <td class="px-5 py-4 text-end font-semibold <%= amount_color_class(template.transaction_kind) %>">
                  <%= format_money(template.source_amount_cents, template.account.currency_code) %>
                </td>
                <td class="px-5 py-4">
                  <div class="flex justify-end gap-2">
                    <%= link_to t(".edit"), edit_transaction_template_path(template), class: "rounded-base px-3 py-2 text-sm font-medium text-fg-brand hover:bg-brand-softer" %>
                    <%= button_to t(".delete"), transaction_template_path(template), method: :delete, form: { data: destructive_confirm_data(t(".delete_confirm")) }, class: "rounded-base px-3 py-2 text-sm font-medium text-danger hover:bg-danger-soft" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="rounded-base border border-default bg-neutral-primary-soft p-8 text-center shadow-xs">
      <h2 class="text-xl font-semibold text-heading"><%= t(".empty_title") %></h2>
      <p class="mx-auto mt-2 max-w-xl text-sm text-body"><%= t(".empty_description") %></p>
      <div class="mt-5"><%= render(ButtonComponent.new(href: new_transaction_template_path)) { t(".create_first") } %></div>
    </div>
  <% end %>
</section>
