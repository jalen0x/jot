<% content_for(:title) { t(".title") } %>
<% field_classes = "bg-neutral-secondary-medium border border-default-medium text-heading text-sm rounded-base focus:ring-brand focus:border-brand block w-full px-3 py-2.5 shadow-xs placeholder:text-body" %>

<section class="mx-auto w-full max-w-4xl space-y-5">
  <header>
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-fg-brand"><%= t(".eyebrow") %></p>
    <h1 class="mt-1 text-2xl font-semibold tracking-tight text-heading sm:text-3xl"><%= t(".title") %></h1>
    <p class="mt-2 max-w-2xl text-sm text-body"><%= t(".description") %></p>
  </header>

  <% if @error_message.present? %>
    <div class="rounded-base border border-danger bg-danger-soft px-4 py-3 text-sm text-fg-danger-strong">
      <%= @error_message %>
    </div>
  <% end %>

  <% if @recovery_codes.present? %>
    <%= render "two_factor_authentications/recovery_code_panel", recovery_codes: @recovery_codes %>
  <% end %>

  <% if @two_factor_authentication %>
    <article class="rounded-base border border-default bg-neutral-primary-soft shadow-xs">
      <div class="border-b border-default px-6 py-5">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-fg-brand"><%= t(".enabled_label") %></p>
        <h2 class="mt-2 text-xl font-semibold text-heading"><%= t(".enabled_heading") %></h2>
        <p class="mt-1 text-sm text-body"><%= t(".enabled_at", time: l(@two_factor_authentication.enabled_at, format: :long)) %></p>
      </div>

      <div class="grid gap-6 p-6 lg:grid-cols-2">
        <%= form_with url: two_factor_recovery_codes_path, scope: :two_factor_recovery_codes, class: "space-y-4" do |form| %>
          <div>
            <%= form.label :current_password, t(".current_password"), class: "mb-2 block text-sm font-medium text-heading" %>
            <%= form.password_field :current_password, required: true, autocomplete: "current-password", class: field_classes %>
          </div>
          <%= form.submit t(".regenerate"), class: "text-body bg-neutral-secondary-medium box-border border border-default-medium hover:bg-neutral-tertiary-medium hover:text-heading focus:ring-4 focus:ring-neutral-tertiary shadow-xs font-medium leading-5 rounded-base text-sm px-4 py-2.5 focus:outline-none" %>
        <% end %>

        <%= form_with url: two_factor_authentication_path, method: :delete, scope: :two_factor_authentication, class: "space-y-4" do |form| %>
          <div>
            <%= form.label :current_password, t(".current_password"), class: "mb-2 block text-sm font-medium text-heading" %>
            <%= form.password_field :current_password, required: true, autocomplete: "current-password", class: field_classes %>
          </div>
          <%= form.submit t(".disable"), class: "text-danger bg-neutral-primary border border-danger hover:bg-danger hover:text-white focus:ring-4 focus:ring-neutral-tertiary font-medium leading-5 rounded-base text-sm px-4 py-2.5 focus:outline-none" %>
        <% end %>
      </div>
    </article>
  <% else %>
    <article class="rounded-base border border-default bg-neutral-primary-soft shadow-xs" data-controller="clipboard">
      <div class="border-b border-default px-6 py-5">
        <h2 class="text-xl font-semibold text-heading"><%= t(".setup_heading") %></h2>
        <p class="mt-2 text-sm text-body"><%= t(".setup_description") %></p>
      </div>

      <div class="grid gap-6 p-6 lg:grid-cols-[auto_1fr] lg:items-start">
        <div class="mx-auto size-44 shrink-0 rounded-base bg-white p-2 shadow-xs lg:mx-0">
          <%= @qr_code_svg.html_safe %>
        </div>

        <div class="space-y-5">
          <div>
            <%= label_tag :totp_setup_secret, t(".manual_entry"), class: "mb-2 block text-sm font-medium text-heading" %>
            <div class="relative">
              <%= text_field_tag :totp_setup_secret, @setup_secret, readonly: true, disabled: true, autocomplete: "off", data: { clipboard_target: "source" }, class: "bg-neutral-secondary-medium border border-default-medium text-body text-sm font-mono rounded-base focus:ring-brand focus:border-brand block w-full ps-3 pe-20 py-2.5 shadow-xs placeholder:text-body" %>
              <button type="button" data-action="clipboard#copy" class="absolute end-1.5 top-1/2 -translate-y-1/2 rounded-base border border-default bg-neutral-primary px-3 py-1.5 text-xs font-semibold text-body hover:bg-neutral-tertiary-soft hover:text-heading focus:outline-none focus:ring-4 focus:ring-neutral-tertiary">
                <span data-clipboard-target="defaultState"><%= t(".copy") %></span>
                <span data-clipboard-target="successState" class="hidden text-fg-brand"><%= t(".copied") %></span>
              </button>
            </div>
          </div>

          <%= form_with url: two_factor_authentication_path, scope: :two_factor_authentication, class: "space-y-5" do |form| %>
            <div>
              <%= form.label :otp_code, t(".verification_code"), class: "mb-2 block text-sm font-medium text-heading" %>
              <%= render "devise/shared/second_factor_code_field", form: form, field: :otp_code, allow_backup_code: false, auto_submit: false %>
            </div>

            <div>
              <%= form.label :current_password, t(".current_password"), class: "mb-2 block text-sm font-medium text-heading" %>
              <%= form.password_field :current_password, required: true, autocomplete: "current-password", class: field_classes %>
            </div>

            <div class="flex items-center justify-end gap-3">
              <%= link_to t(".cancel"), edit_user_registration_path, class: "text-body bg-neutral-secondary-medium box-border border border-default-medium hover:bg-neutral-tertiary-medium hover:text-heading focus:ring-4 focus:ring-neutral-tertiary shadow-xs font-medium leading-5 rounded-base text-sm px-4 py-2.5 focus:outline-none" %>
              <%= form.submit t(".enable"), class: "text-white bg-brand box-border border border-transparent hover:bg-brand-strong focus:ring-4 focus:ring-brand-medium shadow-xs font-medium leading-5 rounded-base text-sm px-4 py-2.5 focus:outline-none" %>
            </div>
          <% end %>
        </div>
      </div>
    </article>
  <% end %>
</section>
