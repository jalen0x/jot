<% content_for :title, t(".title") %>
<% field_classes = "bg-neutral-secondary-medium border border-default-medium text-heading text-sm rounded-base focus:ring-brand focus:border-brand block w-full px-3 py-2.5 shadow-xs placeholder:text-body" %>

<section class="space-y-5">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-fg-brand"><%= t(".eyebrow") %></p>
      <h1 class="mt-1 text-2xl font-semibold tracking-tight text-heading sm:text-3xl"><%= t(".heading") %></h1>
      <p class="mt-2 max-w-2xl text-sm text-body"><%= t(".description") %></p>
    </div>

    <%= button_to t(".export_csv"), data_exports_path, params: { file_format: "csv" }, class: "text-body bg-neutral-secondary-medium box-border border border-default-medium hover:bg-neutral-tertiary-medium hover:text-heading focus:ring-4 focus:ring-neutral-tertiary shadow-xs font-medium leading-5 rounded-base text-sm px-4 py-2.5 focus:outline-none" %>
  </div>

  <%= form_with url: reports_path, method: :get, class: "rounded-base border border-default bg-neutral-primary-soft p-4 shadow-xs" do |form| %>
    <div class="grid gap-4 lg:grid-cols-[1fr_1fr_auto] lg:items-end">
      <div>
        <%= form.label :start_date, t(".start_date"), class: "mb-2 block text-sm font-medium text-heading" %>
        <%= form.date_field :start_date, value: @start_date, class: field_classes %>
      </div>
      <div>
        <%= form.label :end_date, t(".end_date"), class: "mb-2 block text-sm font-medium text-heading" %>
        <%= form.date_field :end_date, value: @end_date, class: field_classes %>
      </div>
      <div class="flex gap-3 lg:justify-end">
        <%= render(ButtonComponent.new(variant: :secondary, href: reports_path)) { t(".reset") } %>
        <%= render(ButtonComponent.new(type: :submit)) { t(".update") } %>
      </div>
    </div>
  <% end %>

  <div class="grid gap-4 lg:grid-cols-3">
    <% [ [ t(".income"), :income_cents, amount_color_class(:income) ], [ t(".expense"), :expense_cents, amount_color_class(:expense) ], [ t(".net"), :net_cents, "text-heading" ] ].each do |label, method_name, color_class| %>
      <article class="rounded-base border border-default bg-neutral-primary-soft p-5 shadow-xs">
        <p class="text-sm font-medium text-body-subtle"><%= label %></p>
        <div class="mt-3 space-y-2">
          <% if @summary.amounts.any? %>
            <% @summary.amounts.each do |amount| %>
              <% signed_color_class = method_name == :net_cents && amount.net_cents.negative? ? amount_color_class(:expense) : color_class %>
              <p class="text-3xl font-semibold tracking-tight <%= signed_color_class %>">
                <%= format_money(amount.public_send(method_name), amount.currency_code, currency_class: "text-sm font-medium text-body-subtle") %>
              </p>
            <% end %>
          <% else %>
            <p class="text-3xl font-semibold tracking-tight <%= color_class %>">
              <%= format_money(0, @default_currency_code, currency_class: "text-sm font-medium text-body-subtle") %>
            </p>
          <% end %>
        </div>
      </article>
    <% end %>
  </div>

  <div class="grid gap-5 xl:grid-cols-[1fr_22rem]">
    <article class="overflow-hidden rounded-base border border-default bg-neutral-primary-soft shadow-xs">
      <div class="border-b border-default px-5 py-4">
        <h2 class="text-lg font-semibold text-heading"><%= t(".category_totals") %></h2>
        <p class="mt-1 text-sm text-body-subtle"><%= t(".category_totals_description") %></p>
      </div>

      <% if @summary.category_amounts.any? %>
        <div class="overflow-x-auto">
          <table class="w-full text-start text-sm text-body">
            <thead class="border-b border-default bg-neutral-secondary-medium text-xs uppercase tracking-wide text-body-subtle">
              <tr>
                <th scope="col" class="px-5 py-3"><%= t(".category") %></th>
                <th scope="col" class="px-5 py-3"><%= t(".currency") %></th>
                <th scope="col" class="px-5 py-3 text-end"><%= t(".amount") %></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-default">
              <% @summary.category_amounts.each do |amount| %>
                <tr class="hover:bg-neutral-secondary-soft">
                  <td class="px-5 py-4 font-medium text-heading"><%= amount.name %></td>
                  <td class="px-5 py-4 text-body-subtle"><%= amount.currency_code %></td>
                  <td class="px-5 py-4 text-end font-semibold <%= amount.amount_cents.negative? ? amount_color_class(:expense) : amount_color_class(:income) %>">
                    <%= format_money(amount.amount_cents, amount.currency_code) %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="px-5 py-10 text-center">
          <h3 class="text-lg font-semibold text-heading"><%= t(".empty_title") %></h3>
          <p class="mt-2 text-sm text-body"><%= t(".empty_description") %></p>
        </div>
      <% end %>
    </article>

    <aside class="rounded-base border border-default bg-neutral-primary-soft p-5 shadow-xs">
      <h2 class="text-lg font-semibold text-heading"><%= t(".report_scope") %></h2>
      <dl class="mt-5 space-y-4 text-sm">
        <div class="flex items-center justify-between gap-4">
          <dt class="text-body-subtle"><%= t(".start_date") %></dt>
          <dd class="font-medium text-heading"><%= l(@start_date, format: :long) %></dd>
        </div>
        <div class="flex items-center justify-between gap-4">
          <dt class="text-body-subtle"><%= t(".end_date") %></dt>
          <dd class="font-medium text-heading"><%= l(@end_date, format: :long) %></dd>
        </div>
        <div class="flex items-center justify-between gap-4">
          <dt class="text-body-subtle"><%= t(".categories") %></dt>
          <dd class="font-medium text-heading"><%= number_with_delimiter(@summary.category_amounts.size) %></dd>
        </div>
      </dl>
    </aside>
  </div>
</section>
