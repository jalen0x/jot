<%# locals: (transaction:, accounts:, transaction_categories:, transaction_tags:, submit_label: nil, submitting_label: nil) %>
<% field_classes = "bg-neutral-secondary-medium border border-default-medium text-heading text-sm rounded-base focus:ring-brand focus:border-brand block w-full px-3 py-2.5 shadow-xs placeholder:text-body" %>
<% submit_label ||= t(".create") %>
<% submitting_label ||= t(".saving") %>
<% selected_kind = (transaction.transaction_kind.presence || "expense") %>
<% kind_options = Transaction.transaction_kinds.except("balance_adjustment").keys %>
<% amount_colors = kind_options.index_with { |k| amount_color_class(k) } %>
<% sections = [["basic", t(".section_basic")], ["map", t(".section_map")], ["pictures", t(".section_pictures")]] %>
<% kind_tab_classes = "rounded-base px-4 py-2 text-sm font-medium transition text-start" %>
<% section_tab_classes = "rounded-base px-3 py-2 text-sm font-medium text-start" %>

<%= form_with model: transaction,
              class: "rounded-base border border-default bg-neutral-primary-soft p-5 shadow-xs",
              data: {
                controller: "transaction-form",
                transaction_form_amount_label_value: t(".amount"),
                transaction_form_source_amount_label_value: t(".source_amount"),
                transaction_form_destination_amount_label_value: t(".destination_amount"),
                transaction_form_amount_colors_value: amount_colors.to_json
              } do |form| %>
  <% if transaction.errors.any? %>
    <div class="mb-5 rounded-base border border-danger bg-danger-soft p-4 text-sm text-fg-danger-strong">
      <p class="font-medium"><%= t(".save_failed") %></p>
      <ul class="mt-2 list-disc ps-5">
        <% transaction.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form.hidden_field :transaction_kind, value: selected_kind, data: { transaction_form_target: "kindInput" } %>

  <div class="grid gap-6 lg:grid-cols-[200px_1fr]">
    <aside class="space-y-4">
      <div role="radiogroup" aria-label="<%= t(".type") %>" class="flex flex-col gap-1 rounded-base border border-default-medium bg-neutral-secondary-medium p-1">
        <% kind_options.each do |kind| %>
          <% active = (kind == selected_kind) %>
          <button type="button" data-action="click->transaction-form#selectKind" data-kind="<%= kind %>" data-transaction-form-target="kindTab" aria-pressed="<%= active %>" class="<%= kind_tab_classes %> <%= active ? "bg-brand text-white shadow-xs" : "text-body hover:text-heading" %>">
            <%= t("transactions.kinds.#{kind}", default: kind.humanize) %>
          </button>
        <% end %>
      </div>

      <div role="tablist" aria-label="<%= t(".sections") %>" class="flex flex-col gap-1">
        <% sections.each_with_index do |(key, label), index| %>
          <% active = index.zero? %>
          <button type="button" data-action="click->transaction-form#selectSection" data-section="<%= key %>" data-transaction-form-target="sectionTab" aria-selected="<%= active %>" class="<%= section_tab_classes %> <%= active ? "text-fg-brand" : "text-body hover:text-heading" %>">
            <%= label %>
          </button>
        <% end %>
      </div>
    </aside>

    <div class="space-y-5">
      <section data-transaction-form-target="section" data-section="basic" class="space-y-4">
        <div class="rounded-base border border-default bg-neutral-secondary-soft p-5">
          <div data-transaction-form-target="sourceAmountField">
            <%= form.label :source_amount, t(".amount"), data: { transaction_form_target: "sourceAmountLabel" }, class: "block mb-2 text-sm font-medium #{amount_color_class(selected_kind)}" %>
            <div class="relative">
              <span class="pointer-events-none absolute inset-y-0 start-0 flex items-center ps-4 text-xl font-semibold <%= amount_color_class(selected_kind) %>" data-transaction-form-target="sourceCurrencyPrefix"></span>
              <%= form.text_field :source_amount,
                value: amount_input_value(transaction.source_amount_cents),
                required: true,
                inputmode: "decimal",
                class: "w-full bg-neutral-primary border border-default-medium text-3xl font-semibold rounded-base focus:ring-brand focus:border-brand px-4 py-3 ps-16 pe-12 shadow-xs #{amount_color_class(selected_kind)}",
                data: { transaction_form_target: "sourceAmountInput", action: "keydown.enter->transaction-form#evaluateAmount" } %>
              <span class="pointer-events-none absolute inset-y-0 end-0 flex items-center pe-3 text-body-subtle" title="<%= t(".formula_hint") %>">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
                  <rect x="4" y="3" width="16" height="18" rx="2" />
                  <line x1="8" y1="7" x2="16" y2="7" />
                  <line x1="8" y1="11" x2="10" y2="11" />
                  <line x1="13" y1="11" x2="16" y2="11" />
                  <line x1="8" y1="15" x2="10" y2="15" />
                  <line x1="13" y1="15" x2="16" y2="15" />
                  <line x1="8" y1="18" x2="10" y2="18" />
                  <line x1="13" y1="18" x2="16" y2="18" />
                </svg>
              </span>
            </div>
          </div>
          <div class="mt-4" data-transaction-form-target="destinationAmountField">
            <%= form.label :destination_amount, t(".destination_amount"), class: "block mb-2 text-sm font-medium #{amount_color_class(selected_kind)}" %>
            <div class="relative">
              <span class="pointer-events-none absolute inset-y-0 start-0 flex items-center ps-4 text-xl font-semibold <%= amount_color_class(selected_kind) %>" data-transaction-form-target="destinationCurrencyPrefix"></span>
              <%= form.text_field :destination_amount,
                value: amount_input_value(transaction.destination_amount_cents),
                inputmode: "decimal",
                class: "w-full bg-neutral-primary border border-default-medium text-3xl font-semibold rounded-base focus:ring-brand focus:border-brand px-4 py-3 ps-16 pe-12 shadow-xs #{amount_color_class(selected_kind)}",
                data: { transaction_form_target: "destinationAmountInput", action: "keydown.enter->transaction-form#evaluateAmount" } %>
            </div>
          </div>
        </div>

        <div>
          <%= form.label :transaction_category_id, t(".category"), class: "mb-2 block text-sm font-medium text-heading" %>
          <%= form.select :transaction_category_id, transaction_categories.map { |c| [category_display_name(c), c.id] }, { prompt: t(".choose_category"), selected: transaction.transaction_category_id }, required: true, class: field_classes %>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <%= form.label :account_id, t(".account"), class: "mb-2 block text-sm font-medium text-heading" %>
            <%= render "account_combobox", form: form, field: :account_id, accounts: accounts, selected_id: transaction.account_id, prompt: t(".choose_account"), action: "change->transaction-form#sourceAccountChanged", target: "sourceAccount" %>
          </div>
          <div data-transaction-form-target="destinationAccountField">
            <%= form.label :destination_account_id, t(".destination_account"), class: "mb-2 block text-sm font-medium text-heading" %>
            <%= render "account_combobox", form: form, field: :destination_account_id, accounts: accounts, selected_id: transaction.destination_account_id, prompt: t(".not_a_transfer"), allow_blank: true, blank_label: t(".not_a_transfer"), action: "change->transaction-form#destinationAccountChanged", target: "destinationAccount" %>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-[2fr_1fr]">
          <div>
            <%= form.label :transacted_at, t(".when"), class: "mb-2 block text-sm font-medium text-heading" %>
            <%= form.datetime_field :transacted_at, required: true, class: field_classes %>
          </div>
          <div>
            <%= form.label :timezone_utc_offset_minutes, t(".timezone_offset"), class: "mb-2 block text-sm font-medium text-heading" %>
            <%= form.number_field :timezone_utc_offset_minutes, class: field_classes, data: { transaction_form_target: "timezoneInput" } %>
          </div>
        </div>

        <div>
          <%= form.label :transaction_tag_ids, t(".tags"), class: "mb-2 block text-sm font-medium text-heading" %>
          <%= form.collection_select :transaction_tag_ids, transaction_tags, :id, :name, {}, multiple: true, class: field_classes %>
        </div>

        <%= render FormField::CheckboxComponent.new(form: form, field: :hide_amount, label: t(".hide_amount")) %>

        <%= render FormField::InputComponent.new(form: form, field: :comment, label: t(".comment"), type: :textarea) %>
      </section>

      <section data-transaction-form-target="section" data-section="map" hidden>
        <div class="grid gap-4 sm:grid-cols-2">
          <%= render FormField::InputComponent.new(form: form, field: :geo_latitude, label: t(".latitude"), type: :number, data: { transaction_form_target: "latitudeInput" }) %>
          <%= render FormField::InputComponent.new(form: form, field: :geo_longitude, label: t(".longitude"), type: :number, data: { transaction_form_target: "longitudeInput" }) %>
        </div>
        <div class="mt-3 flex items-center justify-between gap-3">
          <p class="text-xs text-body-subtle"><%= t(".map_hint") %></p>
          <button type="button" data-action="click->transaction-form#useCurrentLocation"
                  class="text-body bg-neutral-secondary-medium box-border border border-default-medium hover:bg-neutral-tertiary-medium hover:text-heading focus:ring-4 focus:ring-neutral-tertiary shadow-xs font-medium leading-5 rounded-base text-sm px-3 py-1.5 focus:outline-none">
            <%= t(".use_current_location") %>
          </button>
        </div>
      </section>

      <section data-transaction-form-target="section" data-section="pictures" hidden>
        <% if transaction.persisted? %>
          <p class="text-sm text-body-subtle"><%= t(".pictures_hint_persisted") %></p>
        <% else %>
          <div>
            <%= form.label :pictures, t(".pictures"), class: "mb-2 block text-sm font-medium text-heading" %>
            <%= form.file_field :pictures, multiple: true, class: "cursor-pointer bg-neutral-secondary-medium border border-default-medium text-heading text-sm rounded-base focus:ring-brand focus:border-brand block w-full shadow-xs placeholder:text-body" %>
          </div>
        <% end %>
      </section>
    </div>
  </div>

  <div class="mt-6 flex items-center justify-end gap-3 border-t border-default pt-4">
    <%= render(ButtonComponent.new(variant: :secondary, href: transactions_path)) { t(".cancel") } %>
    <% unless transaction.persisted? %>
      <div class="inline-flex rounded-base shadow-xs">
        <button type="submit" name="after_save" value="back" data-turbo-submits-with="<%= submitting_label %>"
                class="text-white bg-brand border border-transparent border-e-white/20 hover:bg-brand-strong focus:ring-4 focus:ring-brand-medium font-medium leading-5 rounded-s-base text-sm px-4 py-2.5 focus:outline-none">
          <%= submit_label %>
        </button>
        <button type="button" data-dropdown-toggle="save-options-menu" data-dropdown-placement="top-end"
                class="text-white bg-brand border border-transparent hover:bg-brand-strong focus:ring-4 focus:ring-brand-medium rounded-e-base px-2 focus:outline-none"
                aria-label="<%= t(".save_options") %>">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" /></svg>
        </button>
      </div>
      <div id="save-options-menu" class="z-30 hidden rounded-base border border-default bg-neutral-primary shadow-md">
        <ul class="py-1 text-sm">
          <li>
            <button type="submit" name="after_save" value="new" class="block w-full px-4 py-2 text-start text-heading hover:bg-neutral-secondary-soft">
              <%= t(".save_and_new") %>
            </button>
          </li>
        </ul>
      </div>
    <% else %>
      <%= render(ButtonComponent.new(type: :submit, data: { turbo_submits_with: submitting_label })) { submit_label } %>
    <% end %>
  </div>
<% end %>
