<%# locals: (transaction:, accounts:, transaction_categories:, transaction_tags:, submit_label: nil, submitting_label: nil) %>
<% submit_label ||= t(".create") %>
<% submitting_label ||= t(".saving") %>
<% selected_kind = (transaction.transaction_kind.presence || "expense") %>
<% kind_options = Transaction.transaction_kinds.except("balance_adjustment").keys %>
<% amount_colors = kind_options.index_with { |k| amount_color_class(k) } %>
<% sections = [["basic", t(".section_basic")], ["map", t(".section_map")], ["pictures", t(".section_pictures")]] %>

<% select_class = "block px-2.5 pb-2.5 pt-4 w-full text-sm text-heading bg-transparent rounded-base border border-default-medium appearance-none focus:outline-none focus:ring-0 focus:border-brand peer" %>
<% floating_label_class = "absolute text-sm text-body duration-300 transform -translate-y-4 scale-75 top-2 z-10 origin-[0] bg-neutral-primary-soft px-2 peer-focus:px-2 peer-focus:text-fg-brand peer-placeholder-shown:scale-100 peer-placeholder-shown:-translate-y-1/2 peer-placeholder-shown:top-1/2 peer-focus:top-2 peer-focus:scale-75 peer-focus:-translate-y-4 start-1" %>

<%= form_with model: transaction,
              class: "rounded-base border border-default bg-neutral-primary-soft p-5 shadow-xs",
              data: {
                controller: "transaction-form",
                transaction_form_amount_label_value: t(".amount"),
                transaction_form_source_amount_label_value: t(".source_amount"),
                transaction_form_destination_amount_label_value: t(".destination_amount"),
                transaction_form_amount_colors_value: amount_colors.to_json
              } do |form| %>
  <% if transaction.errors.any? %>
    <div class="mb-4 flex items-start gap-3 rounded-base border border-danger bg-danger-soft p-3 text-sm text-fg-danger-strong" role="alert">
      <svg class="mt-0.5 h-5 w-5 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
        <path fill-rule="evenodd" d="M18 10A8 8 0 11 2 10a8 8 0 0116 0zm-8-3a1 1 0 00-1 1v4a1 1 0 102 0V8a1 1 0 00-1-1zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
      </svg>
      <div>
        <p class="font-medium"><%= t(".save_failed") %></p>
        <ul class="mt-1 list-disc ps-5">
          <% transaction.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <%= form.hidden_field :transaction_kind, value: selected_kind, data: { transaction_form_target: "kindInput" } %>

  <div class="grid gap-5 lg:grid-cols-[180px_1fr]">
    <aside class="space-y-3">
      <ul role="radiogroup" aria-label="<%= t(".type") %>" class="space-y-1 text-sm font-medium">
        <% kind_options.each do |kind| %>
          <% active = (kind == selected_kind) %>
          <li>
            <button type="button" data-action="click->transaction-form#selectKind" data-kind="<%= kind %>" data-transaction-form-target="kindTab" aria-pressed="<%= active %>"
                    class="inline-flex w-full items-center rounded-base px-4 py-2 leading-5 transition <%= active ? "bg-brand text-white shadow-xs" : "text-body hover:bg-neutral-secondary-medium hover:text-heading" %>">
              <%= t("transactions.kinds.#{kind}", default: kind.humanize) %>
            </button>
          </li>
        <% end %>
      </ul>

      <hr class="border-default">

      <ul role="tablist" aria-label="<%= t(".sections") %>" class="space-y-1 text-sm font-medium">
        <% sections.each_with_index do |(key, label), index| %>
          <% active = index.zero? %>
          <li role="presentation">
            <button type="button" role="tab" data-action="click->transaction-form#selectSection" data-section="<%= key %>" data-transaction-form-target="sectionTab" aria-selected="<%= active %>"
                    class="inline-flex w-full items-center rounded-base px-4 py-1.5 leading-5 transition <%= active ? "text-fg-brand" : "text-body hover:bg-neutral-secondary-medium hover:text-heading" %>">
              <%= label %>
            </button>
          </li>
        <% end %>
      </ul>
    </aside>

    <div class="space-y-3">
      <section data-transaction-form-target="section" data-section="basic" class="space-y-3">
        <div class="grid gap-3 sm:grid-cols-2">
          <div data-transaction-form-target="sourceAmountField">
            <%= render "amount_input_group", form: form,
                                              field: :source_amount,
                                              label_target: "sourceAmountLabel",
                                              prefix_target: "sourceCurrencyPrefix",
                                              input_target: "sourceAmountInput",
                                              label_text: t(".amount"),
                                              cents: transaction.source_amount_cents,
                                              color_class: amount_color_class(selected_kind),
                                              required: true,
                                              show_formula_icon: true,
                                              formula_hint: t(".formula_hint") %>
          </div>
          <div data-transaction-form-target="destinationAmountField">
            <%= render "amount_input_group", form: form,
                                              field: :destination_amount,
                                              prefix_target: "destinationCurrencyPrefix",
                                              input_target: "destinationAmountInput",
                                              label_text: t(".destination_amount"),
                                              cents: transaction.destination_amount_cents,
                                              color_class: amount_color_class(selected_kind),
                                              required: false,
                                              show_formula_icon: false %>
          </div>
        </div>

        <div class="relative">
          <%= form.select :transaction_category_id, transaction_categories.map { |c| [c.display_name, c.id] }, { prompt: " ", selected: transaction.transaction_category_id }, required: true, class: select_class %>
          <%= form.label :transaction_category_id, t(".category"), class: floating_label_class %>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          <%= render "account_combobox", form: form, field: :account_id, accounts: accounts, selected_id: transaction.account_id, label: t(".account"), prompt: t(".choose_account"), action: "change->transaction-form#sourceAccountChanged", target: "sourceAccount" %>
          <div data-transaction-form-target="destinationAccountField">
            <%= render "account_combobox", form: form, field: :destination_account_id, accounts: accounts, selected_id: transaction.destination_account_id, label: t(".destination_account"), prompt: t(".not_a_transfer"), allow_blank: true, blank_label: t(".not_a_transfer"), action: "change->transaction-form#destinationAccountChanged", target: "destinationAccount" %>
          </div>
        </div>

        <div class="grid gap-3 sm:grid-cols-[2fr_1fr]">
          <%= render "floating_field", form: form, field: :transacted_at, label: t(".when"), kind: :datetime_field, required: true %>
          <%= render "floating_field", form: form, field: :timezone_utc_offset_minutes, label: t(".timezone_offset"), kind: :number_field, options: { data: { transaction_form_target: "timezoneInput" } } %>
        </div>

        <div class="relative">
          <%= form.collection_select :transaction_tag_ids, transaction_tags, :id, :name, { include_blank: false }, multiple: true, class: select_class %>
          <%= form.label :transaction_tag_ids, t(".tags"), class: floating_label_class %>
        </div>

        <%= render "floating_field", form: form, field: :comment, label: t(".comment"), kind: :textarea, options: { rows: 3 } %>

        <%= render FormField::CheckboxComponent.new(form: form, field: :hide_amount, label: t(".hide_amount")) %>
      </section>

      <section data-transaction-form-target="section" data-section="map" hidden>
        <div class="grid gap-3 sm:grid-cols-2">
          <%= render "floating_field", form: form, field: :geo_latitude, label: t(".latitude"), kind: :number_field, options: { step: "any", data: { transaction_form_target: "latitudeInput" } } %>
          <%= render "floating_field", form: form, field: :geo_longitude, label: t(".longitude"), kind: :number_field, options: { step: "any", data: { transaction_form_target: "longitudeInput" } } %>
        </div>
        <div class="mt-3 flex items-center justify-between gap-3">
          <p class="text-xs text-body-subtle"><%= t(".map_hint") %></p>
          <button type="button" data-action="click->transaction-form#useCurrentLocation"
                  class="inline-flex items-center text-body bg-neutral-secondary-medium box-border border border-default-medium hover:bg-neutral-tertiary-medium hover:text-heading focus:ring-3 focus:ring-neutral-tertiary-soft shadow-xs font-medium leading-5 rounded-base text-sm px-3 py-1.5 focus:outline-none">
            <svg class="me-1.5 h-4 w-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" /><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.8 13.938h-.011a7 7 0 1 0-11.464.144h-.016l.14.171c.1.127.2.251.3.371L12 21l5.13-6.248c.194-.209.374-.429.54-.659l.13-.155Z" /></svg>
            <%= t(".use_current_location") %>
          </button>
        </div>
      </section>

      <section data-transaction-form-target="section" data-section="pictures" hidden>
        <% if transaction.persisted? %>
          <p class="text-sm text-body-subtle"><%= t(".pictures_hint_persisted") %></p>
        <% else %>
          <label for="<%= form.field_id(:pictures) %>" class="flex flex-col items-center justify-center w-full h-36 bg-neutral-secondary-medium border border-dashed border-default-strong rounded-base cursor-pointer hover:bg-neutral-tertiary-medium">
            <div class="flex flex-col items-center justify-center px-6 py-4 text-body">
              <svg class="mb-2 h-7 w-7" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h3a3 3 0 0 0 0-6h-.025a5.56 5.56 0 0 0 .025-.5A5.5 5.5 0 0 0 7.207 9.021C7.137 9.017 7.071 9 7 9a4 4 0 1 0 0 8h2.167M12 19v-9m0 0-2 2m2-2 2 2" /></svg>
              <p class="mb-0.5 text-sm"><span class="font-semibold text-heading"><%= t(".pictures_dropzone_action") %></span> <%= t(".pictures_dropzone_subaction") %></p>
              <p class="text-xs"><%= t(".pictures_dropzone_hint") %></p>
            </div>
            <%= form.file_field :pictures, multiple: true, class: "hidden" %>
          </label>
        <% end %>
      </section>
    </div>
  </div>

  <div class="mt-5 flex items-center justify-end gap-3 border-t border-default pt-4">
    <%= render(ButtonComponent.new(variant: :secondary, href: transactions_path, data: modal_turbo_frame_data)) { t(".cancel") } %>
    <% unless transaction.persisted? %>
      <div class="inline-flex rounded-base shadow-xs -space-x-px" role="group">
        <button type="submit" name="after_save" value="back" data-turbo-submits-with="<%= submitting_label %>"
                class="inline-flex items-center text-white bg-brand box-border border border-transparent hover:bg-brand-strong focus:ring-4 focus:ring-brand-medium font-medium leading-5 rounded-s-base text-sm px-4 py-2.5 focus:outline-none">
          <%= submit_label %>
        </button>
        <button id="save-options-toggle" data-dropdown-toggle="save-options-menu" data-dropdown-placement="top-end" type="button"
                class="inline-flex items-center justify-center text-white bg-brand box-border border border-transparent hover:bg-brand-strong focus:ring-4 focus:ring-brand-medium font-medium rounded-e-base text-sm w-9 focus:outline-none"
                aria-label="<%= t(".save_options") %>">
          <svg class="h-4 w-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m5 15 7-7 7 7" /></svg>
        </button>
      </div>
      <div id="save-options-menu" class="z-30 hidden bg-neutral-primary-medium border border-default-medium rounded-base shadow-lg w-48">
        <ul class="p-2 text-sm text-body font-medium" aria-labelledby="save-options-toggle">
          <li>
            <button type="submit" name="after_save" value="new" class="inline-flex items-center w-full p-2 hover:bg-neutral-tertiary-medium hover:text-heading rounded">
              <%= t(".save_and_new") %>
            </button>
          </li>
        </ul>
      </div>
    <% else %>
      <%= render(ButtonComponent.new(type: :submit, data: { turbo_submits_with: submitting_label })) { submit_label } %>
    <% end %>
  </div>
<% end %>
