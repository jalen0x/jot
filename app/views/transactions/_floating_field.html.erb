<%# locals: (form:, field:, label:, kind: :text_field, value: nil, required: false, options: {}) %>
<%
  input_class = "block px-2.5 pb-2.5 pt-4 w-full text-sm text-heading bg-transparent rounded-base border border-default-medium appearance-none focus:outline-none focus:ring-0 focus:border-brand peer"
  input_class = "#{input_class} #{options.delete(:input_extra_class)}".strip if options[:input_extra_class]
  label_class = "absolute text-sm text-body duration-300 transform -translate-y-4 scale-75 top-2 z-10 origin-[0] bg-neutral-primary-soft px-2 peer-focus:px-2 peer-focus:text-fg-brand peer-placeholder-shown:scale-100 peer-placeholder-shown:-translate-y-1/2 peer-placeholder-shown:top-1/2 peer-focus:top-2 peer-focus:scale-75 peer-focus:-translate-y-4 start-1"
  label_class = "#{label_class} #{options.delete(:label_extra_class)}".strip if options[:label_extra_class]
  field_opts = { placeholder: " ", class: input_class }.merge(options)
  field_opts[:value] = value unless value.nil?
  field_opts[:required] = required if required
%>
<div class="relative">
  <% case kind %>
  <% when :textarea %>
    <%= form.text_area field, **field_opts %>
  <% when :datetime_field %>
    <%= form.datetime_field field, **field_opts %>
  <% when :number_field %>
    <%= form.number_field field, **field_opts %>
  <% when :select %>
    <%# select handled inline by caller; this branch unused %>
  <% else %>
    <%= form.text_field field, **field_opts %>
  <% end %>
  <%= form.label field, label, class: label_class %>
</div>
