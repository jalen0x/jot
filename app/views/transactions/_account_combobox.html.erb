<%# locals: (form:, field:, accounts:, selected_id: nil, prompt: nil, allow_blank: false, action: nil, target: nil, blank_label: nil) %>
<div class="relative" data-controller="combobox"
     data-combobox-placeholder-value="<%= prompt %>"
     <%= "data-action=\"#{action}\"".html_safe if action.present? %>
     <%= "data-transaction-form-target=\"#{target}\"".html_safe if target.present? %>>
  <%= form.hidden_field field, value: selected_id, data: { combobox_target: "input" } %>

  <button type="button" data-action="click->combobox#toggle" data-combobox-target="button"
          class="inline-flex items-center justify-between w-full bg-neutral-secondary-medium box-border border border-default-medium hover:bg-neutral-tertiary-medium hover:text-heading focus:ring-4 focus:ring-neutral-tertiary font-medium leading-5 rounded-base text-sm px-3 py-2.5 shadow-xs focus:outline-none text-start">
    <span class="truncate" data-combobox-target="display"></span>
    <svg class="w-4 h-4 ms-1.5 -me-0.5 text-body-subtle" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
      <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m19 9-7 7-7-7" />
    </svg>
  </button>

  <div data-combobox-target="panel" hidden class="absolute z-30 mt-1 w-full bg-neutral-primary-medium border border-default-medium rounded-base shadow-lg">
    <div class="p-2 border-b border-default-medium">
      <div class="relative">
        <div class="absolute inset-y-0 start-0 flex items-center ps-3 pointer-events-none">
          <svg class="w-4 h-4 text-body" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <path stroke="currentColor" stroke-linecap="round" stroke-width="2" d="m21 21-3.5-3.5M17 10a7 7 0 1 1-14 0 7 7 0 0 1 14 0Z" />
          </svg>
        </div>
        <input type="search" data-combobox-target="search" data-action="input->combobox#filter"
               autocomplete="off"
               placeholder="<%= t("transactions.form.search_account") %>"
               class="block w-full p-2 ps-9 bg-neutral-secondary-medium border border-default-medium text-heading text-sm rounded-base focus:ring-brand focus:border-brand shadow-xs placeholder:text-body">
      </div>
    </div>

    <ul data-combobox-target="list" class="max-h-72 overflow-y-auto p-2 text-sm text-body font-medium">
      <% if allow_blank %>
        <li data-combobox-target="option" data-value="" data-display="<%= blank_label %>" data-search="" data-currency=""
            data-action="click->combobox#select"
            class="inline-flex items-center w-full gap-3 p-2 hover:bg-neutral-tertiary-medium hover:text-heading rounded cursor-pointer">
          <span class="h-3 w-3 shrink-0 rounded-full border border-default-medium"></span>
          <span class="flex-1 text-body-subtle"><%= blank_label %></span>
        </li>
      <% end %>
      <% accounts.each do |account| %>
        <li data-combobox-target="option" data-value="<%= account.id %>"
            data-display="<%= account_display_name(account) %>"
            data-search="<%= [account.name, account.currency_code].join(' ').downcase %>"
            data-currency="<%= account.currency_code %>"
            data-action="click->combobox#select"
            class="inline-flex items-center w-full gap-3 p-2 hover:bg-neutral-tertiary-medium hover:text-heading rounded cursor-pointer">
          <span class="h-3 w-3 shrink-0 rounded-full border border-default-medium" style="background-color: #<%= account.color_hex %>"></span>
          <div class="min-w-0 flex-1">
            <p class="truncate text-heading"><%= account_display_name(account) %></p>
            <p class="text-xs text-body-subtle"><%= format_money(account.balance_cents, account.currency_code) %></p>
          </div>
        </li>
      <% end %>
    </ul>
  </div>
</div>
