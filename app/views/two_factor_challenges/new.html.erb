<% content_for :title, t(".title") %>

<section class="mx-auto w-full max-w-md space-y-5">
  <header>
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-fg-brand"><%= t(".eyebrow") %></p>
    <h1 class="mt-1 text-2xl font-semibold tracking-tight text-heading sm:text-3xl"><%= t(".heading") %></h1>
    <p class="mt-2 text-sm text-body"><%= t(".description") %></p>
  </header>

  <%= form_with url: two_factor_challenge_path, scope: :two_factor_challenge, class: "rounded-base border border-default bg-neutral-primary-soft p-5 shadow-xs" do |form| %>
    <div class="mb-5">
      <%= form.label :otp_code, t(".verification_or_recovery_code"), class: "mb-2 block text-sm font-medium text-heading" %>
      <%= render "devise/shared/second_factor_code_field", form: form, field: :otp_code, allow_backup_code: true, auto_submit: false %>
    </div>

    <div class="flex justify-end">
      <%= render(ButtonComponent.new(type: :submit, data: { turbo_submits_with: t(".verifying") })) { t(".verify_code") } %>
    </div>
  <% end %>
</section>
