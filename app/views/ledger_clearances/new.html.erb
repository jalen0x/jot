<% content_for :title, t(".title") %>
<% field_classes = "bg-neutral-secondary-medium border border-default-medium text-heading text-sm rounded-base focus:ring-brand focus:border-brand block w-full px-3 py-2.5 shadow-xs placeholder:text-body" %>
<% danger_button_classes = "text-danger bg-neutral-primary border border-danger hover:bg-danger hover:text-white focus:ring-4 focus:ring-neutral-tertiary font-medium leading-5 rounded-base text-sm px-4 py-2.5 focus:outline-none" %>

<section class="space-y-5">
  <header>
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-fg-brand"><%= t(".eyebrow") %></p>
    <h1 class="mt-1 text-2xl font-semibold tracking-tight text-heading sm:text-3xl"><%= t(".heading") %></h1>
    <p class="mt-2 max-w-2xl text-sm text-body"><%= t(".description") %></p>
  </header>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <% [ [ t(".counts.accounts"), @ledger_counts[:accounts] ], [ t(".counts.categories"), @ledger_counts[:transaction_categories] ], [ t(".counts.tags"), @ledger_counts[:transaction_tags] ], [ t(".counts.transactions"), @ledger_counts[:transactions] ] ].each do |label, value| %>
      <article class="rounded-base border border-default bg-neutral-primary-soft p-5 shadow-xs">
        <p class="text-sm font-medium text-body-subtle"><%= label %></p>
        <p class="mt-2 text-3xl font-semibold text-heading"><%= number_with_delimiter(value) %></p>
      </article>
    <% end %>
  </div>

  <% if @ledger_clearance_error.present? %>
    <div class="rounded-base border border-danger bg-danger-soft p-4 text-sm text-fg-danger-strong">
      <%= @ledger_clearance_error %>
    </div>
  <% end %>

  <div class="grid gap-5 lg:grid-cols-2">
    <%= form_with url: ledger_clearance_path, scope: :ledger_clearance, class: "rounded-base border border-danger-subtle bg-danger-soft p-6 shadow-xs" do |form| %>
      <%= form.hidden_field :clearance_scope, value: "transactions" %>
      <span class="flex h-11 w-11 items-center justify-center rounded-base bg-neutral-primary text-fg-danger"><%= app_shell_icon(:list, css_class: "h-5 w-5") %></span>
      <h2 class="mt-4 text-lg font-semibold text-heading"><%= t(".clear_transactions_heading") %></h2>
      <p class="mt-2 text-sm text-body"><%= t(".clear_transactions_description") %></p>
      <div class="mt-5">
        <%= form.label :current_password, t(".current_password"), class: "mb-2 block text-sm font-medium text-heading" %>
        <%= form.password_field :current_password, autocomplete: "current-password", class: field_classes %>
      </div>
      <div class="mt-5">
        <%= form.submit t(".clear_transactions"), class: danger_button_classes %>
      </div>
    <% end %>

    <%= form_with url: ledger_clearance_path, scope: :ledger_clearance, class: "rounded-base border border-danger bg-danger-soft p-6 shadow-xs" do |form| %>
      <%= form.hidden_field :clearance_scope, value: "all" %>
      <span class="flex h-11 w-11 items-center justify-center rounded-base bg-neutral-primary text-fg-danger"><%= app_shell_icon(:database, css_class: "h-5 w-5") %></span>
      <h2 class="mt-4 text-lg font-semibold text-heading"><%= t(".clear_all_heading") %></h2>
      <p class="mt-2 text-sm text-body"><%= t(".clear_all_description") %></p>
      <div class="mt-5">
        <%= form.label :current_password, t(".current_password"), class: "mb-2 block text-sm font-medium text-heading" %>
        <%= form.password_field :current_password, autocomplete: "current-password", class: field_classes %>
      </div>
      <div class="mt-5">
        <%= form.submit t(".clear_all"), class: danger_button_classes %>
      </div>
    <% end %>
  </div>
</section>
