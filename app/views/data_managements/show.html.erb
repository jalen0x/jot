<% content_for :title, t(".title") %>
<%
  stat_cards = [
    [ t(".stats.accounts"), @statistics.account_count ],
    [ t(".stats.categories"), @statistics.transaction_category_count ],
    [ t(".stats.tags"), @statistics.transaction_tag_count ],
    [ t(".stats.transactions"), @statistics.transaction_count ],
    [ t(".stats.pictures"), @statistics.transaction_picture_count ],
    [ t(".stats.insights"), @statistics.insight_explorer_count ],
    [ t(".stats.templates"), @statistics.transaction_template_count ],
    [ t(".stats.scheduled"), @statistics.scheduled_transaction_count ]
  ]
  secondary_button_classes = "text-body bg-neutral-secondary-medium box-border border border-default-medium hover:bg-neutral-tertiary-medium hover:text-heading focus:ring-4 focus:ring-neutral-tertiary shadow-xs font-medium leading-5 rounded-base text-sm px-4 py-2.5 focus:outline-none"
%>

<section class="space-y-5">
  <div>
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-fg-brand"><%= t(".eyebrow") %></p>
    <h1 class="mt-1 text-2xl font-semibold tracking-tight text-heading sm:text-3xl"><%= t(".heading") %></h1>
    <p class="mt-2 max-w-2xl text-sm text-body"><%= t(".description") %></p>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <% stat_cards.each do |label, value| %>
      <article class="rounded-base border border-default bg-neutral-primary-soft p-5 shadow-xs">
        <p class="text-sm font-medium text-body-subtle"><%= label %></p>
        <p class="mt-2 text-3xl font-semibold text-heading"><%= number_with_delimiter(value) %></p>
      </article>
    <% end %>
  </div>

  <div class="grid gap-4 lg:grid-cols-3">
    <article class="rounded-base border border-default bg-neutral-primary-soft p-6 shadow-xs">
      <span class="flex h-11 w-11 items-center justify-center rounded-base bg-brand-softer text-fg-brand"><%= app_shell_icon(:database, css_class: "h-5 w-5") %></span>
      <h2 class="mt-4 text-lg font-semibold text-heading"><%= t(".export_heading") %></h2>
      <p class="mt-2 text-sm text-body"><%= t(".export_description") %></p>
      <div class="mt-5 flex flex-wrap gap-3">
        <%= button_to t(".export_csv"), data_exports_path, method: :post, params: { file_format: "csv" }, class: secondary_button_classes %>
        <%= button_to t(".export_tsv"), data_exports_path, method: :post, params: { file_format: "tsv" }, class: secondary_button_classes %>
        <%= button_to t(".export_json"), data_exports_path, method: :post, params: { file_format: "json" }, class: secondary_button_classes %>
      </div>
    </article>

    <article class="rounded-base border border-default bg-neutral-primary-soft p-6 shadow-xs">
      <span class="flex h-11 w-11 items-center justify-center rounded-base bg-brand-softer text-fg-brand"><%= app_shell_icon(:upload, css_class: "h-5 w-5") %></span>
      <h2 class="mt-4 text-lg font-semibold text-heading"><%= t(".import_heading") %></h2>
      <p class="mt-2 text-sm text-body"><%= t(".import_description") %></p>
      <div class="mt-5">
        <%= render(ButtonComponent.new(href: new_import_batch_path)) { t(".import_action") } %>
      </div>
    </article>

    <article class="rounded-base border border-danger-subtle bg-danger-soft p-6 shadow-xs">
      <span class="flex h-11 w-11 items-center justify-center rounded-base bg-neutral-primary text-fg-danger"><%= app_shell_icon(:lock, css_class: "h-5 w-5") %></span>
      <h2 class="mt-4 text-lg font-semibold text-heading"><%= t(".clear_heading") %></h2>
      <p class="mt-2 text-sm text-body"><%= t(".clear_description") %></p>
      <div class="mt-5">
        <%= render(ButtonComponent.new(variant: :danger, href: new_ledger_clearance_path)) { t(".clear_action") } %>
      </div>
    </article>
  </div>
</section>
