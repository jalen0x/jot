<% content_for :title, "Data management" %>
<%
  stat_cards = [
    [ "Accounts", @statistics.account_count ],
    [ "Categories", @statistics.transaction_category_count ],
    [ "Tags", @statistics.transaction_tag_count ],
    [ "Transactions", @statistics.transaction_count ],
    [ "Pictures", @statistics.transaction_picture_count ],
    [ "Insights", @statistics.insight_explorer_count ],
    [ "Templates", @statistics.transaction_template_count ],
    [ "Scheduled", @statistics.scheduled_transaction_count ]
  ]
  secondary_button_classes = "text-body bg-neutral-secondary-medium box-border border border-default-medium hover:bg-neutral-tertiary-medium hover:text-heading focus:ring-4 focus:ring-neutral-tertiary shadow-xs font-medium leading-5 rounded-base text-sm px-4 py-2.5 focus:outline-none"
%>

<section class="flex flex-col gap-6">
  <div>
    <p class="text-sm font-medium uppercase tracking-wide text-body-subtle">Ledger</p>
    <h1 class="mt-1 text-3xl font-semibold tracking-tight text-heading">Data management</h1>
    <p class="mt-2 max-w-2xl text-sm text-body">Review your stored ledger data, export transactions, import transactions, or clear ledger data.</p>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <% stat_cards.each do |label, value| %>
      <article class="bg-neutral-primary-soft border border-default rounded-base p-5 shadow-xs">
        <p class="text-sm font-medium text-body-subtle"><%= label %></p>
        <p class="mt-2 text-3xl font-semibold text-heading"><%= number_with_delimiter(value) %></p>
      </article>
    <% end %>
  </div>

  <div class="grid gap-4 lg:grid-cols-3">
    <article class="bg-neutral-primary-soft border border-default rounded-base p-6 shadow-xs">
      <h2 class="text-lg font-semibold text-heading">Export transactions</h2>
      <p class="mt-2 text-sm text-body">Download your current Rails ledger transactions as CSV or TSV.</p>
      <div class="mt-5 flex flex-wrap gap-3">
        <%= button_to "Export CSV", data_exports_path, method: :post, params: { file_format: "csv" }, class: secondary_button_classes %>
        <%= button_to "Export TSV", data_exports_path, method: :post, params: { file_format: "tsv" }, class: secondary_button_classes %>
      </div>
    </article>

    <article class="bg-neutral-primary-soft border border-default rounded-base p-6 shadow-xs">
      <h2 class="text-lg font-semibold text-heading">Import transactions</h2>
      <p class="mt-2 text-sm text-body">Paste CSV or TSV transaction rows and process them through the import job.</p>
      <div class="mt-5">
        <%= render(ButtonComponent.new(href: new_import_batch_path)) { "Import transactions" } %>
      </div>
    </article>

    <article class="bg-neutral-primary-soft border border-default rounded-base p-6 shadow-xs">
      <h2 class="text-lg font-semibold text-heading">Clear data</h2>
      <p class="mt-2 text-sm text-body">Clear transactions or all ledger data after confirming your password.</p>
      <div class="mt-5">
        <%= render(ButtonComponent.new(variant: :danger, href: new_ledger_clearance_path)) { "Clear ledger data" } %>
      </div>
    </article>
  </div>
</section>
