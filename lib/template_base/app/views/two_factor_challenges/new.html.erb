<% content_for(:title) { t(".title") } %>

<section class="mx-auto w-full max-w-md space-y-6">
  <header class="space-y-2 text-center">
    <h1 class="text-2xl font-bold text-heading"><%= t(".title") %></h1>
    <p class="text-sm text-body"><%= t(".description") %></p>
  </header>

  <% if @error_message.present? %>
    <div class="rounded-base border border-danger bg-danger-soft px-4 py-3 text-sm text-fg-danger-strong">
      <%= @error_message %>
    </div>
  <% end %>

  <%= form_with url: two_factor_challenge_path, scope: :two_factor_challenge, class: "rounded-base border border-default bg-neutral-primary-soft p-6 shadow-xs sm:p-8 space-y-5" do |form| %>
    <div>
      <%= form.label :otp_code, t(".verification_code"), class: "block mb-2 text-sm font-medium text-heading" %>
      <%= render "devise/shared/second_factor_code_field", form: form, field: :otp_code, allow_backup_code: true, auto_submit: true %>
      <p class="mt-3 text-xs text-body-subtle"><%= t(".backup_code_hint") %></p>
    </div>

    <div class="flex items-center justify-end gap-3">
      <%= form.submit t(".verify"), class: "text-white bg-brand box-border border border-transparent hover:bg-brand-strong focus:ring-4 focus:ring-brand-medium shadow-xs font-medium leading-5 rounded-base text-sm px-4 py-2.5 focus:outline-none" %>
    </div>
  <% end %>
</section>
